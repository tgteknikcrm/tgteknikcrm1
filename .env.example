# Supabase - al: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# İlk yönetici telefonu (trigger bu numara ile kayıt olunca otomatik admin yapar)
NEXT_PUBLIC_ADMIN_PHONE=+905426469070

# ── Cloudflare R2 (mesaj eki depolama) ─────────────────────────────
# Boş bırakılırsa Supabase storage kullanılır (eski davranış).
# 1 dolu olunca yeni eklemeler R2'ye gider, eskiler aynı yerde kalır.
NEXT_PUBLIC_R2_ENABLED=0
NEXT_PUBLIC_R2_PUBLIC_URL=https://cdn.tgteknik.com.tr  # worker custom domain
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tgteknikcrm-attach
# Worker'ın okuyabilmesi için tg_jwt cookie hangi parent domain'e yazılsın?
# Hem Vercel hem Worker bu domain'in subdomain'i olmalı.
R2_COOKIE_DOMAIN=.tgteknik.com.tr
